NODE_ENV=development
PORT=3000
# App
APP_NAME=ComicHub
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/comichub

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=

# SMTP (email)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
MAIL_FROM=noreply@comichub.com

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=ap-southeast-1
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=

# Import proxy (rotation proxy for scraping)
USE_PROXY=0
PROXY_URL=http://user:pass@ip:port
# Scrapfly (backup, only if proxy/direct blocked)
USE_SCRAPFLY=0
SCRAPFLY_KEY=
