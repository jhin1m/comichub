# Copy this file to `.env.test.local` (gitignored) and fill with real test credentials.
# Playwright config auto-loads `.env.test.local` before running E2E tests.
# NEVER commit `.env.test.local` — it contains real login credentials.

# Credentials for the authenticated E2E flows (login, profile, interaction tests).
# Use a DEDICATED test account, not a production admin. If the account has admin
# privileges, scope it to the test/staging environment only.
E2E_TEST_EMAIL=your-test-account@example.com
E2E_TEST_PASSWORD=replace-with-strong-password
