# Cloudflare API — used only to auto-create DNS A records (orange cloud, proxied).
# API Token scopes required:
#   - Zone:Zone:Read
#   - Zone:DNS:Edit
# Create at: https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=

# Domain
DOMAIN=example.com
API_SUBDOMAIN=api

# VPS public IP — leave empty to auto-detect via api.ipify.org
VPS_PUBLIC_IP=

# Git
GIT_REPO=git@github.com:user/comichub.git
GIT_BRANCH=main

# Docker Compose — explicit project name keeps image tags stable across deploys.
# Must match the prefix used for :latest and :rollback tags in deploy.sh.
COMPOSE_PROJECT_NAME=comichub

# App
APP_DIR=/var/www/comichub
DB_PASSWORD=changeme_strong_password
NEXT_PUBLIC_API_URL=https://api.example.com/api/v1
# Internal API URL for SSR — bypasses Cloudflare. Set automatically in docker-compose.yml.
# INTERNAL_API_URL=http://backend:3001/api/v1
NEXT_PUBLIC_SITE_NAME=ComicHub
NEXT_PUBLIC_SITE_LOGO=
NEXT_PUBLIC_SITE_URL=https://example.com
FRONTEND_URL=https://example.com

# ─── Comix.to import campaign (optional) ─────────────────────────
# Telegram bot for campaign notifications. Create via @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Parallel import shards — one proxy endpoint per shard for independent IPs.
# Comma-separated, no spaces. Example: http://user:pass@1.2.3.4:8020,http://user:pass@5.6.7.8:8020
# Empty → campaign falls back to serial single-shard (no proxy).
PROXY_URLS=
