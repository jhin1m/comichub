# Caddy reverse proxy config for ComicHub.
#
# TLS: Cloudflare Origin Certificate (15-year validity).
#   - Generate in CF dashboard: SSL/TLS → Origin Server → Create Certificate
#   - Hostnames: {$DOMAIN}, *.{$DOMAIN}
#   - Save cert as: deploy/certs/origin.pem
#   - Save key as:  deploy/certs/origin.key
#
# Requires CF SSL/TLS mode: Full (strict)
# Requires CF DNS records: orange cloud (proxied)
#
# If you later switch to grey cloud (DNS only) or want auto TLS,
# remove `auto_https off` and the `tls` directives — Caddy will use Let's Encrypt.
{
	# Disable automatic HTTPS (ACME) — we use CF Origin Cert instead.
	auto_https off
	# Admin API bound to loopback only.
	admin localhost:2019
}

# Frontend (Next.js)
{$DOMAIN}:443 {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
	encode zstd gzip

	# NC1: real client IP must come from CF-Connecting-IP (single-hop, trusted by CF).
	# Strip inbound X-Forwarded-For so a client-spoofed header cannot poison downstream
	# rate-limit / view-count / Turnstile remoteip buckets. Fallback to {remote_host}
	# (Cloudflare edge IP) only if CF header is absent (e.g., direct-to-origin probe).
	request_header -X-Forwarded-For
	reverse_proxy frontend:3000 {
		header_up X-Real-IP {http.request.header.CF-Connecting-IP:{remote_host}}
		header_up X-Forwarded-For {http.request.header.CF-Connecting-IP:{remote_host}}
		header_up X-Forwarded-Proto https
	}
	header {
		# Strip server fingerprint.
		-Server
		# HSTS — CF already sends this but belt-and-suspenders.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}

# Backend API (NestJS)
{$API_SUBDOMAIN}.{$DOMAIN}:443 {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
	encode zstd gzip

	# NC1: see frontend block. Same XFF-strip + CF-Connecting-IP forward logic.
	request_header -X-Forwarded-For
	reverse_proxy backend:3001 {
		header_up X-Real-IP {http.request.header.CF-Connecting-IP:{remote_host}}
		header_up X-Forwarded-For {http.request.header.CF-Connecting-IP:{remote_host}}
		header_up X-Forwarded-Proto https

		# Active health check — skip upstream while warming up (returns 503).
		health_uri /api/v1/health
		health_interval 5s
		health_timeout 5s
		fail_duration 30s
	}
	header {
		-Server
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}
